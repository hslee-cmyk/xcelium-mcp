{
  "xcelium-mcp": {
    "type": "stdio",
    "command": "ssh",
    "args": [
      "-o", "BatchMode=yes",
      "-o", "ServerAliveInterval=30",
      "-o", "ServerAliveCountMax=3",
      "cloud0",
      "/opt/mcp-env/bin/python", "-m", "xcelium_mcp.stdio_forward",
      "<remote $HOME>/.xcelium_mcp/run/xcelium-mcp.sock"
    ],
    "env": {}
  }
}
